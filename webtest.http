@host = https://rj-mcp-d365-server-1-e4d4ghcxf5d3dkbr.eastus2-01.azurewebsites.net

###############################################################################
# REST endpoints (Postman-style, NOT what Azure AI Foundry uses)
###############################################################################

### LIVE – Health
GET {{host}}/health

### LIVE – Root
GET {{host}}/

### LIVE – List tools (REST)
GET {{host}}/tools

### LIVE – Read pick lines (REST)
POST {{host}}/tools/readOpenLines
Content-Type: application/json

{
  "subscriptionId": "so_out_pick",
  "numberOfRecords": 1
}

### LIVE – Confirm work order (REST)
POST {{host}}/tools/confirmWork
Content-Type: application/json

{
  "workLinePairId":     "MHWKL-000000003",
  "workLineRecId":      "68719480121",
  "fromLicensePlate":   "A0001",
  "targetLicensePlate": "A0001",
  "workLineNumber":     "1",
  "quantity":           "2",
  "workLinePairIdRef":  "MHWKL-000000003",
  "workType":           "Pick",
  "fromLocation":       "FL-001",
  "inboundTransType":   "WorkConfirm",
  "messageId":          "msg-ABC1234567"
}

###############################################################################
# MCP Streamable HTTP endpoint (what Azure AI Foundry calls)
#   All requests are POST {{host}}/mcp  with JSON-RPC 2.0 body
###############################################################################

### MCP – initialize (Foundry's first call on Connect)
POST {{host}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "initialize",
  "params": {
    "protocolVersion": "2025-03-26",
    "capabilities": {},
    "clientInfo": { "name": "rest-client", "version": "1.0" }
  }
}

### MCP – tools/list
POST {{host}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/list",
  "params": {}
}

### MCP – tools/call readOpenLines
POST {{host}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "tools/call",
  "params": {
    "name": "readOpenLines",
    "arguments": {
      "subscriptionId": "so_out_pick",
      "numberOfRecords": 1
    }
  }
}

### MCP – tools/call confirmWork
POST {{host}}/mcp
Content-Type: application/json
Accept: application/json, text/event-stream

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "tools/call",
  "params": {
    "name": "confirmWork",
    "arguments": {
      "workLinePairId":     "MHWKL-000000003",
      "workLineRecId":      "68719480121",
      "fromLicensePlate":   "A0001",
      "targetLicensePlate": "A0001",
      "workLineNumber":     "1",
      "quantity":           "2",
      "workLinePairIdRef":  "MHWKL-000000003",
      "workType":           "Pick",
      "fromLocation":       "FL-001",
      "inboundTransType":   "WorkConfirm",
      "messageId":          "msg-ABC1234567"
    }
  }
}
