# D365 OAuth 2.0 v2 — values from your Azure AD administrator
D365_TENANT_ID=your-azure-tenant-id-here
D365_CLIENT_ID=your-app-registration-client-id-here
D365_CLIENT_SECRET=your-app-registration-client-secret-here
D365_BASE_URL=https://xxx.sandbox.operations.dynamics.com

# MCP Server
PORT=3000
SERVER_API_KEY=generate-with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
